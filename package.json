		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@types/node": "^22.15.17",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"prettier": "^3.5.4",
		"typescript": "^5.9.3"
	}
}
