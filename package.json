{
	"name": "nethack",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"lint": "next lint",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"format:js": "prettier --write \"**/*.{js,jsx,ts,tsx}\"",
		"format:html": "prettier --write \"**/*.html\"",
